{
  "name": "stegokit-backend",
  "version": "1.0.0",
  "description": "StegoKit backend – Express REST API for steganography operations",
  "main": "server.js",
  "scripts": {
    "start": "node --max-old-space-size=4096 server.js",
    "dev": "nodemon --exec \"node --max-old-space-size=4096\" server.js",
    "test": "jest --coverage"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jimp": "^0.22.12",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.35.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>",
      "<rootDir>/../tests"
    ],
    "moduleDirectories": [
      "node_modules",
      "<rootDir>/node_modules"
    ],
    "coverageDirectory": "../tests/coverage"
  }
}
