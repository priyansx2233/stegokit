# Required when the frontend is deployed separately from the API.
# Example for Render deployment: https://your-stegokit-backend.onrender.com/api
# The URL should point to your backend API endpoint and must NOT have a trailing slash.
VITE_API_URL=

# Use / for root deployments, or /stegokit/ for subpath deployments like GitHub Pages
VITE_BASE_PATH=/

# Local dev proxy target. The frontend calls /api in development, and Vite proxies it here.
VITE_DEV_API_PROXY=http://localhost:5000
